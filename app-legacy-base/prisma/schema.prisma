  active
  disabled
}

model PortalUser {
  id           String           @id @default(uuid()) @db.Uuid
  customerId   String           @map("customer_id") @db.Uuid
  contactId    String?          @unique @map("contact_id") @db.Uuid
  username     String           @unique
  passwordHash String           @map("password_hash")
  displayName  String           @map("display_name")
  status       PortalUserStatus @default(active)
  lastLoginAt  DateTime?        @map("last_login_at")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  customer     Customer         @relation(fields: [customerId], references: [id])
  contact      Contact?         @relation(fields: [contactId], references: [id])

  @@index([customerId])
  @@map("portal_users")
}

model PortalVideo {
  id           String   @id @default(uuid()) @db.Uuid
  title        String
  description  String?
  youtubeUrl   String   @map("youtube_url")
  categoryTag  String?  @map("category_tag")
  thumbnailUrl String?  @map("thumbnail_url")
  sortOrder    Int      @default(0) @map("sort_order")
  isPublished  Boolean  @default(true) @map("is_published")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([isPublished, sortOrder])
  @@map("portal_videos")
}

model PortalDownload {
  id          String   @id @default(uuid()) @db.Uuid
  title       String
  description String?
  filePath    String?  @map("file_path")
  externalUrl String?  @map("external_url")
  version     String?
  categoryTag String?  @map("category_tag")
  fileSize    Int?     @map("file_size")
  manualPath  String?  @map("manual_path")
  imagePath   String?  @map("image_path")
  sortOrder   Int      @default(0) @map("sort_order")
  isPublished Boolean  @default(true) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([isPublished, sortOrder])
  @@map("portal_downloads")
}

model Page {
  id             String   @id @default(uuid()) @db.Uuid
  slug           String   @unique
  title          String
  pageType       String   @map("page_type")
  sections       Json     @default("{}")
  richContent    String?  @map("rich_content") @db.Text
  excerpt        String?  @db.Text
  targetKeyword  String?  @map("target_keyword") @db.VarChar(255)
  searchIntent   String?  @map("search_intent") @db.VarChar(50)
  secondaryKeywords Json? @map("secondary_keywords")
  reviewedAt     DateTime? @map("reviewed_at")
  seoTitle       String?  @map("seo_title")
  seoDescription String?  @map("seo_description")
  ogImage        String?  @map("og_image")
  isPublished    Boolean  @default(true) @map("is_published")
  sortOrder      Int      @default(0) @map("sort_order")
  updatedBy      String?  @map("updated_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([isPublished, sortOrder])
  @@map("pages")
}

model GuideArticle {
  id             String   @id @default(uuid()) @db.Uuid
  slug           String   @unique
  title          String
  excerpt        String?  @db.Text
  coverImage     String?  @map("cover_image")
  content        String   @db.Text
  contentGroup   String   @default("guide") @map("content_group") @db.VarChar(50)
  contentType    String   @default("guide") @map("content_type") @db.VarChar(50)
  topic          String?  @db.VarChar(100)
  targetKeyword  String?  @map("target_keyword") @db.VarChar(255)
  searchIntent   String?  @map("search_intent") @db.VarChar(50)
  secondaryKeywords Json? @map("secondary_keywords")
  faq            Json?
  authorName     String?  @map("author_name") @db.VarChar(120)
  reviewedAt     DateTime? @map("reviewed_at")
  relatedServiceSlugs Json? @map("related_service_slugs")
  relatedProductSlugs Json? @map("related_product_slugs")
  legacyPath     String?  @map("legacy_path")
  redirectStatus String   @default("none") @map("redirect_status") @db.VarChar(30)
  targetGuideSlug String? @map("target_guide_slug") @db.VarChar(255)
  seoTitle       String?  @map("seo_title")
  seoDescription String?  @map("seo_description")
  isPublished    Boolean  @default(false) @map("is_published")
  publishedAt    DateTime? @map("published_at")
  sortOrder      Int      @default(0) @map("sort_order")
  updatedBy      String?  @map("updated_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([isPublished, publishedAt, sortOrder])
  @@index([topic, contentType])
  @@map("guide_articles")
}
