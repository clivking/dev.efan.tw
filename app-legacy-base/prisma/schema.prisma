generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma-v7"
  runtime  = "nodejs"
}

datasource db {
  provider = "postgresql"
}

model Setting {
  id          String      @id @default(uuid()) @db.Uuid
  key         String      @unique
  value       String
  type        SettingType
  category    String
  description String?
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@index([category])
  @@map("settings")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  action    String
  tableName String   @map("table_name")
  recordId  String   @map("record_id") @db.Uuid
  before    Json?
  after     Json?
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id])

  @@index([tableName, createdAt])
  @@index([userId, createdAt])
  @@index([createdAt])
  @@map("audit_logs")
}

model User {
  id               String          @id @default(uuid()) @db.Uuid
  username         String          @unique
  passwordHash     String          @map("password_hash")
  name             String
  mobile           String?
  email            String?
  role             UserRole        @default(admin)
  isActive         Boolean         @default(true) @map("is_active")
  lastLoginAt      DateTime?       @map("last_login_at")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  auditLogs            AuditLog[]
  recordedPayments     Payment[]       @relation("PaymentRecorder")
  createdTemplates     QuoteTemplate[] @relation("TemplateCreator")
  createdTokens        QuoteToken[]    @relation("TokenCreator")
  createdQuotes        Quote[]
  transferredSessions  ChatSession[]   @relation("SessionTransferredTo")

  @@map("users")
}

model DailyCounter {
  id           String   @id @default(uuid()) @db.Uuid
  date         DateTime @db.Date
  type         String
  currentValue Int      @map("current_value")

  @@unique([date, type], name: "date_type")
  @@map("daily_counters")
}

model ContactRequest {
  name             String
  phone            String
  email            String?
  services         String[]
  details          String?
  budgetTier       String?
  status           String    @default("new")
  ipAddress        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  customerId       String?   @map("customer_id") @db.Uuid
  id               String    @id @default(uuid()) @db.Uuid
  consultationData Json?     @map("consultation_data")
  address          String?
  lineId           String?   @map("line_id")
  source           String    @default("website")
  customer         Customer? @relation(fields: [customerId], references: [id])
  chatSessions     ChatSession[]

  @@map("contact_requests")
}

model Customer {
  id              String           @id @default(uuid()) @db.Uuid
  customerNumber  String           @unique @map("customer_number")
  notes           String?
  isDeleted       Boolean          @default(false) @map("is_deleted")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  lastDealAt      DateTime?        @map("last_deal_at")
  lastQuoteAt     DateTime?        @map("last_quote_at")
  companyNames    CompanyName[]
  contactRequests ContactRequest[]
  contacts        Contact[]
  locations       Location[]
  quotes          Quote[]
  chatSessions    ChatSession[]
  portalToken        String?       @unique @map("portal_token")
  portalTokenExpires DateTime?     @map("portal_token_expires")
  portalUsers        PortalUser[]

  @@index([customerNumber])
  @@map("customers")
}

model CompanyName {
  id          String   @id @default(uuid()) @db.Uuid
  customerId  String   @map("customer_id") @db.Uuid
  companyName String   @map("company_name")
  taxId       String?  @map("tax_id")
  isPrimary   Boolean  @default(false) @map("is_primary")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  customer    Customer @relation(fields: [customerId], references: [id])
  quotes      Quote[]

  @@index([customerId])
  @@index([companyName])
  @@map("company_names")
}

model Contact {
  id         String         @id @default(uuid()) @db.Uuid
  customerId String         @map("customer_id") @db.Uuid
  name       String
  mobile     String?
  phone      String?
  fax        String?
  email      String?
  isPrimary  Boolean        @default(false) @map("is_primary")
  notes      String?
  sortOrder  Int            @default(0) @map("sort_order")
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")
  title      String?
  hasLine    Boolean        @default(false) @map("has_line")
  customer   Customer       @relation(fields: [customerId], references: [id])
  quoteLinks QuoteContact[]
  portalUser PortalUser?

  @@index([customerId])
  @@map("contacts")
}

model Location {
  id         String   @id @default(uuid()) @db.Uuid
  customerId String   @map("customer_id") @db.Uuid
  name       String
  address    String
  isPrimary  Boolean  @default(false) @map("is_primary")
  notes      String?
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  customer   Customer @relation(fields: [customerId], references: [id])
  quotes     Quote[]

  @@index([customerId])
  @@map("locations")
}

model ProductCategory {
  id              String            @id @default(uuid()) @db.Uuid
  name            String
  sortOrder       Int               @default(0) @map("sort_order")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  parentId        String?           @map("parent_id") @db.Uuid
  showOnWebsite   Boolean           @default(true) @map("show_on_website")
  seoTitle        String?           @map("seo_title") @db.VarChar(255)
  seoDescription  String?           @map("seo_description")
  seoSlug         String?           @unique @map("seo_slug") @db.VarChar(255)
  specTemplate    Json?             @map("spec_template")
  parent          ProductCategory?  @relation("CategoryToCategory", fields: [parentId], references: [id])
  children        ProductCategory[] @relation("CategoryToCategory")
  products        Product[]
  quoteTemplates  QuoteTemplate[]

  @@map("product_categories")
}

model Product {
  id                  String          @id @default(uuid()) @db.Uuid
  categoryId          String          @map("category_id") @db.Uuid
  brand               String?
  model               String?
  name                String
  description         String?
  quoteName           String?         @map("quote_name")
  quoteDesc           String?         @map("quote_desc")
  type                ProductType     @default(single)
  unit                String?
  costPrice           Decimal         @map("cost_price") @db.Decimal(12, 0)
  marketPrice         Decimal?        @map("market_price") @db.Decimal(12, 0)
  sellingPrice        Decimal         @map("selling_price") @db.Decimal(12, 0)
  repairPrice         Decimal?        @map("repair_price") @db.Decimal(12, 0)
  isHiddenItem        Boolean         @default(false) @map("is_hidden_item")
  isQuickAccess       Boolean         @default(false) @map("is_quick_access")
  isAI                Boolean         @default(false) @map("is_ai")
  isHot               Boolean         @default(false) @map("is_hot")
  isNew               Boolean         @default(false) @map("is_new")
  productUrl          String?         @map("product_url")
  notes               String?
  isDeleted           Boolean         @default(false) @map("is_deleted")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")
  currentStock        Int             @default(0) @map("current_stock")
  lowStockThreshold   Int             @default(0) @map("low_stock_threshold")
  trackInventory      Boolean         @default(false) @map("track_inventory")
  // === 網站展示 / SEO ===
  sortOrder           Int             @default(0) @map("sort_order")
  showOnWebsite       Boolean         @default(false) @map("show_on_website")
  seoTitle            String?         @map("seo_title") @db.VarChar(255)
  seoDescription      String?         @map("seo_description")
  seoSlug             String?         @unique @map("seo_slug") @db.VarChar(255)
  seoKeywords         String?         @map("seo_keywords") @db.VarChar(500)
  targetKeyword       String?         @map("target_keyword") @db.VarChar(255)
  secondaryKeywords   Json?           @map("secondary_keywords")
  searchIntent        String?         @map("search_intent") @db.VarChar(50)
  websiteDescription  String?         @map("website_description")
  sourceUrl           String?         @map("source_url")
  sourceCheckedAt     DateTime?       @map("source_checked_at")
  contentStatus       String          @default("draft") @map("content_status") @db.VarChar(50)
  contentReviewedAt   DateTime?       @map("content_reviewed_at")
  needsRevalidation   Boolean         @default(false) @map("needs_revalidation")
  // === 產品詳情內容（Phase 17C）===
  content             Json?           @map("content")
  specifications      Json?           @map("specifications")
  videoUrl            String?         @map("video_url")
  faqs                Json?           @map("faqs")
  useCases            Json?           @map("use_cases")
  bestFor             Json?           @map("best_for")
  notFor              Json?           @map("not_for")
  compatibility       Json?           @map("compatibility")
  installationNotes   Json?           @map("installation_notes")
  maintenanceTips     Json?           @map("maintenance_tips")
  comparisonNotes     String?         @map("comparison_notes")
  imageAlt            String?         @map("image_alt")
  imageCaption        String?         @map("image_caption")
  // === SEO Schema.org 結構化資料 ===
  seoRatingValue      Decimal?        @map("seo_rating_value") @db.Decimal(2, 1)
  seoRatingCount      Int?            @map("seo_rating_count")
  seoReviews          Json?           @map("seo_reviews")
  bundleItems         BundleItem[]    @relation("BundleParent")
  includedIn          BundleItem[]    @relation("BundleChild")
  category            ProductCategory @relation(fields: [categoryId], references: [id])
  quoteItems          QuoteItem[]
  templateItems       TemplateItem[]

  @@index([categoryId])
  @@index([categoryId, sortOrder])
  @@index([brand])
  @@index([showOnWebsite])
  @@map("products")
}

model BundleItem {
  id        String   @id @default(uuid()) @db.Uuid
  bundleId  String   @map("bundle_id") @db.Uuid
  productId String   @map("product_id") @db.Uuid
  quantity  Int      @default(1)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  bundle    Product  @relation("BundleParent", fields: [bundleId], references: [id])
  product   Product  @relation("BundleChild", fields: [productId], references: [id])

  @@map("bundle_items")
}

model Quote {
  id                String           @id @default(uuid()) @db.Uuid
  quoteNumber       String           @unique @map("quote_number")
  customerId        String?          @map("customer_id") @db.Uuid
  companyNameId     String?          @map("company_name_id") @db.Uuid
  locationId        String?          @map("location_id") @db.Uuid
  status            QuoteStatus      @default(draft)
  taxRate           Decimal          @map("tax_rate") @db.Decimal(5, 2)
  subtotalAmount    Decimal          @default(0) @map("subtotal_amount") @db.Decimal(12, 2)
  discountAmount    Decimal          @default(0) @map("discount_amount") @db.Decimal(12, 2)
  discountNote      String?          @map("discount_note")
  totalAmount       Decimal          @default(0) @map("total_amount") @db.Decimal(12, 2)
  totalCost         Decimal          @default(0) @map("total_cost") @db.Decimal(12, 2)
  totalProfit       Decimal          @default(0) @map("total_profit") @db.Decimal(12, 2)
  taxCost           Decimal          @default(0) @map("tax_cost") @db.Decimal(12, 2)
  actualProfit      Decimal          @default(0) @map("actual_profit") @db.Decimal(12, 2)
  internalNote      String?          @map("internal_note")
  customerNote      String?          @map("customer_note")
  parentQuoteId     String?          @map("parent_quote_id") @db.Uuid
  isSuperseded      Boolean          @default(false) @map("is_superseded")
  templateId        String?          @map("template_id") @db.Uuid
  validUntil        DateTime         @map("valid_until") @db.Date
  createdBy         String           @map("created_by") @db.Uuid
  confirmedAt       DateTime?        @map("confirmed_at")
  sentAt            DateTime?        @map("sent_at")
  signedAt          DateTime?        @map("signed_at")
  paidAt            DateTime?        @map("paid_at")
  isDeleted         Boolean          @default(false) @map("is_deleted")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  name              String?          @map("name")
  hasTransportFee   Boolean          @default(false) @map("has_transport_fee")
  transportFee      Decimal          @default(0) @map("transport_fee") @db.Decimal(12, 2)
  transportFeeCost  Decimal          @default(0) @map("transport_fee_cost") @db.Decimal(12, 2)
  nameEn            String?          @map("name_en")
  completedAt         DateTime?        @map("completed_at")
  constructionAt      DateTime?        @map("construction_at")
  invoiceIssuedAt     DateTime?        @map("invoice_issued_at") @db.Date
  firstViewedAt       DateTime?        @map("first_viewed_at")
  selectedVariantId   String?          @map("selected_variant_id") @db.Uuid
  viewCount           Int              @default(0) @map("view_count")
  warrantyExpiresAt   DateTime?        @map("warranty_expires_at") @db.Date
  warrantyMonths      Int              @default(12) @map("warranty_months")
  warrantyStartDate   DateTime?        @map("warranty_start_date") @db.Date
  warrantyNotifiedAt  DateTime?        @map("warranty_notified_at")
  completion_note     String?          @map("completion_note")
  discountExpiryAt    DateTime?        @map("discount_expiry_at")
  area                String?          @map("area")
  payments          Payment[]
  contacts          QuoteContact[]
  items             QuoteItem[]
  signatures        QuoteSignature[]
  tokens            QuoteToken[]
  variants          QuoteVariant[]   @relation("QuoteVariants")
  chatSessions      ChatSession[]
  companyName       CompanyName?     @relation(fields: [companyNameId], references: [id])
  createdByUser     User             @relation(fields: [createdBy], references: [id])
  customer          Customer?        @relation(fields: [customerId], references: [id])
  location          Location?        @relation(fields: [locationId], references: [id])
  parentQuote       Quote?           @relation("QuoteVersions", fields: [parentQuoteId], references: [id])
  childQuotes       Quote[]          @relation("QuoteVersions")
  selectedVariant   QuoteVariant?    @relation("SelectedVariant", fields: [selectedVariantId], references: [id])
  template          QuoteTemplate?   @relation(fields: [templateId], references: [id])

  @@index([quoteNumber])
  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@index([parentQuoteId])
  @@map("quotes")
}

model QuoteItem {
  id           String        @id @default(uuid()) @db.Uuid
  quoteId      String        @map("quote_id") @db.Uuid
  productId    String?       @map("product_id") @db.Uuid
  name         String
  description  String?
  unit         String?
  quantity     Int           @default(1)
  unitPrice    Decimal       @map("unit_price") @db.Decimal(12, 2)
  costPrice    Decimal       @map("cost_price") @db.Decimal(12, 2)
  subtotal     Decimal       @db.Decimal(12, 2)
  isHiddenItem Boolean       @default(false) @map("is_hidden_item")
  internalNote String?       @map("internal_note")
  customerNote String?       @map("customer_note")
  sortOrder    Int           @default(0) @map("sort_order")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  variantId    String?       @map("variant_id") @db.Uuid
  product      Product?      @relation(fields: [productId], references: [id])
  quote        Quote         @relation(fields: [quoteId], references: [id])
  variant      QuoteVariant? @relation(fields: [variantId], references: [id])

  @@index([quoteId, sortOrder])
  @@map("quote_items")
}

model QuoteTemplate {
  id            String           @id @default(uuid()) @db.Uuid
  name          String
  categoryId    String?          @map("category_id") @db.Uuid
  notes         String?
  createdBy     String           @map("created_by") @db.Uuid
  isDeleted     Boolean          @default(false) @map("is_deleted")
  taxRate       Decimal          @default(0) @map("tax_rate") @db.Decimal(5, 2)
  discountAmount Decimal         @default(0) @map("discount_amount") @db.Decimal(12, 2)
  discountNote  String?          @map("discount_note")
  hasTransportFee Boolean        @default(false) @map("has_transport_fee")
  transportFee  Decimal          @default(0) @map("transport_fee") @db.Decimal(12, 2)
  transportFeeCost Decimal       @default(0) @map("transport_fee_cost") @db.Decimal(12, 2)
  internalNote  String?          @map("internal_note")
  customerNote  String?          @map("customer_note")
  warrantyMonths Int?            @map("warranty_months")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  variantConfig Json?            @map("variant_config")
  category      ProductCategory? @relation(fields: [categoryId], references: [id])
  createdByUser User             @relation("TemplateCreator", fields: [createdBy], references: [id])
  quotes        Quote[]
  items         TemplateItem[]

  @@map("quote_templates")
}

model TemplateItem {
  id         String        @id @default(uuid()) @db.Uuid
  templateId String        @map("template_id") @db.Uuid
  productId  String?       @map("product_id") @db.Uuid
  name       String
  description String?
  unit       String?
  quantity   Int           @default(1)
  unitPrice  Decimal       @map("unit_price") @db.Decimal(12, 2)
  costPrice  Decimal       @map("cost_price") @db.Decimal(12, 2)
  isHiddenItem Boolean     @default(false) @map("is_hidden_item")
  internalNote String?     @map("internal_note")
  customerNote String?     @map("customer_note")
  variantSourceId String?  @map("variant_source_id") @db.Uuid
  sortOrder  Int           @default(0) @map("sort_order")
  createdAt  DateTime      @default(now()) @map("created_at")
  product    Product?      @relation(fields: [productId], references: [id])
  template   QuoteTemplate @relation(fields: [templateId], references: [id])

  @@index([templateId])
  @@map("template_items")
}

model UploadedFile {
  id         String   @id @default(uuid()) @db.Uuid
  filename   String
  filepath   String
  mimetype   String
  size       Int
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id") @db.Uuid
  uploadedBy String?  @map("uploaded_by") @db.Uuid
  sortOrder    Int      @default(0) @map("sort_order")
  title        String?
  description  String?  @map("file_description")
  docType      String?  @map("doc_type")
  displayMode  String   @default("contain") @map("display_mode") @db.VarChar(20)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([entityType, entityId])
  @@map("uploaded_files")
}

model QuoteContact {
  id        String   @id @default(uuid()) @db.Uuid
  quoteId   String   @map("quote_id") @db.Uuid
  contactId String   @map("contact_id") @db.Uuid
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  quote     Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@unique([quoteId, contactId])
  @@map("quote_contacts")
}

model QuoteToken {
  id        String      @id @default(uuid()) @db.Uuid
  quoteId   String      @map("quote_id") @db.Uuid
  token     String      @unique
  isActive  Boolean     @default(true) @map("is_active")
  expiresAt DateTime?   @map("expires_at")
  createdBy String      @map("created_by") @db.Uuid
  createdAt DateTime    @default(now()) @map("created_at")
  creator   User        @relation("TokenCreator", fields: [createdBy], references: [id])
  quote     Quote       @relation(fields: [quoteId], references: [id])
  views     QuoteView[]

  @@index([quoteId])
  @@map("quote_tokens")
}

model QuoteView {
  id              String     @id @default(uuid()) @db.Uuid
  tokenId         String     @map("token_id") @db.Uuid
  ipAddress       String?    @map("ip_address")
  userAgent       String?    @map("user_agent")
  deviceType      String?    @map("device_type")
  durationSeconds Int?       @map("duration_seconds")
  createdAt       DateTime   @default(now()) @map("created_at")
  token           QuoteToken @relation(fields: [tokenId], references: [id])

  @@index([tokenId, createdAt])
  @@map("quote_views")
}

model QuoteSignature {
  id             String        @id @default(uuid()) @db.Uuid
  quoteId        String        @map("quote_id") @db.Uuid
  variantId      String?       @map("variant_id") @db.Uuid
  signerName     String        @map("signer_name")
  signerTitle    String?       @map("signer_title")
  signatureImage String        @map("signature_image")
  ipAddress      String?       @map("ip_address")
  userAgent      String?       @map("user_agent")
  signedAt       DateTime      @map("signed_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  quote          Quote         @relation(fields: [quoteId], references: [id])
  variant        QuoteVariant? @relation(fields: [variantId], references: [id])

  @@index([quoteId])
  @@map("quote_signatures")
}

model QuoteVariant {
  id               String           @id @default(uuid()) @db.Uuid
  quoteId          String           @map("quote_id") @db.Uuid
  name             String
  isRecommended    Boolean          @default(false) @map("is_recommended")
  subtotalAmount   Decimal          @default(0) @map("subtotal_amount") @db.Decimal(12, 2)
  totalAmount      Decimal          @default(0) @map("total_amount") @db.Decimal(12, 2)
  totalCost        Decimal          @default(0) @map("total_cost") @db.Decimal(12, 2)
  sortOrder        Int              @default(0) @map("sort_order")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  items            QuoteItem[]
  signatures       QuoteSignature[]
  quote            Quote            @relation("QuoteVariants", fields: [quoteId], references: [id])
  selectedByQuotes Quote[]          @relation("SelectedVariant")

  @@index([quoteId, sortOrder])
  @@map("quote_variants")
}

model Payment {
  id         String        @id @default(uuid()) @db.Uuid
  quoteId    String        @map("quote_id") @db.Uuid
  type       PaymentType
  amount     Decimal       @db.Decimal(12, 2)
  method     PaymentMethod
  paidAt     DateTime      @map("paid_at") @db.Date
  notes      String?
  recordedBy String        @map("recorded_by") @db.Uuid
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")
  quote      Quote         @relation(fields: [quoteId], references: [id])
  recorder   User          @relation("PaymentRecorder", fields: [recordedBy], references: [id])

  @@index([quoteId])
  @@map("payments")
}

model Notification {
  id                String              @id @default(uuid()) @db.Uuid
  type              String
  title             String
  body              String
  entityType        String?             @map("entity_type")
  entityId          String?             @map("entity_id") @db.Uuid
  channel           NotificationChannel
  status            NotificationStatus  @default(pending)
  errorMessage      String?             @map("error_message")
  telegramMessageId Int?                @map("telegram_message_id")
  sentAt            DateTime?           @map("sent_at")
  createdAt         DateTime            @default(now()) @map("created_at")

  @@index([type, createdAt])
  @@index([entityType, entityId])
  @@index([telegramMessageId])
  @@map("notifications")
}

model ChatSession {
  id                 String            @id @default(uuid()) @db.Uuid
  source             ChatSessionSource
  customerId         String?           @map("customer_id") @db.Uuid
  quoteId            String?           @map("quote_id") @db.Uuid
  visitorName        String?           @map("visitor_name")
  visitorContact     String?           @map("visitor_contact")
  visitorEmail       String?           @map("visitor_email")
  visitorLineId      String?           @map("visitor_line_id")
  contactRequestId   String?           @map("contact_request_id") @db.Uuid
  status             ChatSessionStatus @default(active)
  transferredTo      String?           @map("transferred_to") @db.Uuid
  transferredAt      DateTime?         @map("transferred_at")
  telegramMessageId  Int?              @map("telegram_message_id")
  metadata           Json?
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  customer           Customer?         @relation(fields: [customerId], references: [id])
  quote              Quote?            @relation(fields: [quoteId], references: [id])
  contactRequest     ContactRequest?   @relation(fields: [contactRequestId], references: [id])
  transferredToUser  User?             @relation("SessionTransferredTo", fields: [transferredTo], references: [id])
  messages           ChatMessage[]

  @@index([status])
  @@index([customerId])
  @@index([createdAt])
  @@map("chat_sessions")
}

model ChatMessage {
  id            String          @id @default(uuid()) @db.Uuid
  sessionId     String          @map("session_id") @db.Uuid
  role          ChatMessageRole
  content       String
  senderName    String?         @map("sender_name")
  provider         String?
  model            String?
  promptTokens     Int?            @map("prompt_tokens")
  completionTokens Int?            @map("completion_tokens")
  totalTokens      Int?            @map("total_tokens")
  estimatedCost    Decimal?        @map("estimated_cost") @db.Decimal(10, 8)
  extractedInfo    Json?           @map("extracted_info")
  createdAt     DateTime        @default(now()) @map("created_at")
  session       ChatSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("chat_messages")
}

model AIUsageEvent {
  id                   BigInt    @id @default(autoincrement())
  source               String
  provider             String?
  model                String?
  inputTokens          Int       @default(0) @map("input_tokens")
  outputTokens         Int       @default(0) @map("output_tokens")
  totalTokens          Int       @default(0) @map("total_tokens")
  estimatedCost        Decimal   @default(0) @map("estimated_cost") @db.Decimal(12, 8)
  messageCount         Int       @default(1) @map("message_count")
  relatedChatMessageId String?   @unique @map("related_chat_message_id") @db.Uuid
  metadata             Json?
  createdAt            DateTime  @default(now()) @map("created_at")

  @@index([createdAt(sort: Desc)])
  @@index([source, createdAt(sort: Desc)])
  @@map("ai_usage_events")
}

