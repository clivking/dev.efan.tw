    "check:text-integrity": "npm run check:encoding && npm run check:garbled-copy",
    "verify:content-qa": "bash scripts/content-qa.sh",
    "repair:garbled-db": "node scripts/repair-garbled-db.mjs",
    "analyze": "cross-env ANALYZE=true next build --webpack",
    "start": "next start --port 5100",
    "lint": "eslint .",
    "script:check-db": "tsx scripts/check-db.ts",
    "script:check-uploads": "node scripts/check-uploads-integrity.mjs",
