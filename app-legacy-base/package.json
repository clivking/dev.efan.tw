{
  "name": "efan-working-copy",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 5100",
    "prebuild": "npm run check:encoding",
    "build": "npm run build:webpack",
    "build:turbopack": "next build",
    "build:webpack": "node scripts/run-webpack-build.mjs",
    "check:encoding": "node scripts/check-encoding.mjs",
    "check:garbled-copy": "node scripts/scan-garbled-copy.mjs src prisma scripts docs README.md",
