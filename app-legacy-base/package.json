    "script:fix-uploads-docs": "node scripts/fix-uploads-document-mappings.mjs",
    "script:test-prisma": "node scripts/test-prisma.mjs",
    "script:reset-user": "node scripts/force-reset-user.mjs",
    "script:setup-user": "node scripts/setup-user.mjs",
    "verify:quote-save": "node scripts/verify-quote-save-regression.mjs",
    "verify:guides-smoke": "tsx scripts/verify-guides-smoke.ts",
    "db:seed": "node prisma/seed.mjs"
